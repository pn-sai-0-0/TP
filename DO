# 🎮 EASIEST CONTROLLER (ONLY ESSENTIALS)

```java
package com.example.demo.controller;

import com.example.demo.model.User;
import com.example.demo.repository.UserRepository;

import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.web.bind.annotation.*;

@Controller
public class UserController {

    private final UserRepository repo;

    // Constructor Injection
    public UserController(UserRepository repo) {
        this.repo = repo;
    }

    // 1. Show form + list
    @GetMapping("/")
    public String home(Model model) {
        model.addAttribute("user", new User());      // empty form object
        model.addAttribute("list", repo.findAll());  // show all users
        return "form"; // form.html
    }

    // 2. Save user (Add + Update both)
    @PostMapping("/save")
    public String save(@ModelAttribute User user) {
        repo.save(user);  // JPA handles insert/update
        return "redirect:/";
    }

    // 3. Edit user
    @GetMapping("/edit/{id}")
    public String edit(@PathVariable int id, Model model) {
        model.addAttribute("user", repo.findById(id).orElse(new User()));
        model.addAttribute("list", repo.findAll());
        return "form";
    }

    // 4. Delete user
    @GetMapping("/delete/{id}")
    public String delete(@PathVariable int id) {
        repo.deleteById(id);
        return "redirect:/";
    }
}
```

